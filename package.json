{
  "name": "colorpickerapp",
  "version": "1.0.0",
  "description": "Global Color Picker",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --mac",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.ayaz.colorpicker",
    "productName": "Global Color Picker",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png"
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^26.15.3"
  }
}
